{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPassRoleForEcsTasks",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::318798562215:role/ecsTaskExecutionRole",
        "arn:aws:iam::318798562215:role/jenkins-kre-task-role"
      ],
      "Condition": {
        "StringEquals": { "iam:PassedToService": "ecs-tasks.amazonaws.com" }
      }
    }
  ]
}
